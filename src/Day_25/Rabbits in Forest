    public int numRabbits(int[] answers) {
            HashMap<Integer , Integer> m = new HashMap<>();
            for(int val :answers ){
                m.put(val , m.getOrDefault(val , 0) + 1);
            }

            int ans =0;
            for(int key : m.keySet()){
                int gs = key + 1;
                int reportees = m.get(key);
                int ng = (int) Math.ceil((reportees*1.0)/gs*1.0);
                ans += gs * ng;
            }
            return ans;
    }